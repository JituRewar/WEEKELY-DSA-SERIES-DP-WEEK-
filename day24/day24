recursion.cpp
class Solution {
public:

    int solve(int start,int end){

        if(start>=end)
            return 0;

        int ans=INT_MAX;

        for(int i=start;i<=end;i++){

            int cost=i+max(
                solve(start,i-1),
                solve(i+1,end)
            );

            ans=min(ans,cost);
        }

        return ans;
    }

    int getMoneyAmount(int n) {

        return solve(1,n);
    }
};
memoization.cpp
class Solution {
public:

    int solve(int start,int end,vector<vector<int>>& dp){

        if(start>=end)
            return 0;

        if(dp[start][end]!=-1)
            return dp[start][end];

        int ans=INT_MAX;

        for(int i=start;i<=end;i++){

            int cost=i+max(
                solve(start,i-1,dp),
                solve(i+1,end,dp)
            );

            ans=min(ans,cost);
        }

        return dp[start][end]=ans;
    }

    int getMoneyAmount(int n) {

        vector<vector<int>> dp(n+2,vector<int>(n+2,-1));

        return solve(1,n,dp);
    }
};
tabulation.cpp
class Solution {
public:

    int getMoneyAmount(int n) {

        vector<vector<int>> dp(n+2,vector<int>(n+2,0));

        for(int start=n;start>=1;start--){

            for(int end=start+1;end<=n;end++){

                int ans=INT_MAX;

                for(int i=start;i<=end;i++){

                    int cost=i+max(
                        dp[start][i-1],
                        dp[i+1][end]
                    );

                    ans=min(ans,cost);
                }

                dp[start][end]=ans;
            }
        }

        return dp[1][n];
    }
};
