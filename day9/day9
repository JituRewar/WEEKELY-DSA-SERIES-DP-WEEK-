#include <iostream>
#include <vector>
#include <climits>
using namespace std;

//---------------------------------------------------------
// Approach 1 : Pure Recursion
//---------------------------------------------------------

int solveRec(int n) {

    if (n == 0)
        return 0;

    int ans = INT_MAX;

    for (int i = 1; i * i <= n; i++) {
        ans = min(ans, 1 + solveRec(n - i * i));
    }

    return ans;
}

//---------------------------------------------------------
// Approach 2 : Memoization
//---------------------------------------------------------

int solveMem(int n, vector<int>& dp) {

    if (n == 0)
        return 0;

    if (dp[n] != -1)
        return dp[n];

    int ans = INT_MAX;

    for (int i = 1; i * i <= n; i++) {
        ans = min(ans, 1 + solveMem(n - i * i, dp));
    }

    return dp[n] = ans;
}

//---------------------------------------------------------
// Approach 3 : Tabulation
//---------------------------------------------------------

int solveTab(int n) {

    vector<int> dp(n + 1, INT_MAX);

    dp[0] = 0;

    for (int i = 1; i <= n; i++) {

        for (int j = 1; j * j <= i; j++) {

            dp[i] = min(dp[i], 1 + dp[i - j * j]);
        }
    }

    return dp[n];
}

//---------------------------------------------------------

int main() {

    int n = 13;

    cout << "Recursion : " << solveRec(n) << endl;

    vector<int> dp(n + 1, -1);

    cout << "Memoization : " << solveMem(n, dp) << endl;

    cout << "Tabulation : " << solveTab(n) << endl;

    return 0;
}
