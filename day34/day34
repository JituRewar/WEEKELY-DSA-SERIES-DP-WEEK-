class Solution {
public:

    vector<int> nextSmaller(vector<int>& arr){

        int n=arr.size();

        vector<int> ans(n);

        stack<int> st;
        st.push(-1);

        for(int i=n-1;i>=0;i--){

            while(st.top()!=-1 && arr[st.top()]>=arr[i])
                st.pop();

            ans[i]=st.top();

            st.push(i);
        }

        return ans;
    }

    vector<int> prevSmaller(vector<int>& arr){

        int n=arr.size();

        vector<int> ans(n);

        stack<int> st;
        st.push(-1);

        for(int i=0;i<n;i++){

            while(st.top()!=-1 && arr[st.top()]>=arr[i])
                st.pop();

            ans[i]=st.top();

            st.push(i);
        }

        return ans;
    }

    int largestRectangleArea(vector<int>& heights){

        int n=heights.size();

        vector<int> next=nextSmaller(heights);
        vector<int> prev=prevSmaller(heights);

        int area=0;

        for(int i=0;i<n;i++){

            if(next[i]==-1)
                next[i]=n;

            int width=next[i]-prev[i]-1;

            area=max(area,heights[i]*width);
        }

        return area;
    }

    int maximalRectangle(vector<vector<char>>& matrix) {

        if(matrix.empty())
            return 0;

        int row=matrix.size();
        int col=matrix[0].size();

        vector<int> heights(col,0);

        int ans=0;

        for(int i=0;i<row;i++){

            for(int j=0;j<col;j++){

                if(matrix[i][j]=='1')
                    heights[j]++;
                else
                    heights[j]=0;
            }

            ans=max(ans,largestRectangleArea(heights));
        }

        return ans;
    }
};
