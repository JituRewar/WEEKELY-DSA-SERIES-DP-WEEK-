recursion.cpp
class Solution {
public:

    int solve(int n){

        if(n<=1)
            return 1;

        int ans=0;

        for(int i=1;i<=n;i++){

            ans+=solve(i-1)*solve(n-i);
        }

        return ans;
    }

    int numTrees(int n) {

        return solve(n);
    }
};
memoization.cpp
class Solution {
public:

    int solve(int n,vector<int>& dp){

        if(n<=1)
            return 1;

        if(dp[n]!=-1)
            return dp[n];

        int ans=0;

        for(int i=1;i<=n;i++){

            ans+=solve(i-1,dp)*solve(n-i,dp);
        }

        return dp[n]=ans;
    }

    int numTrees(int n) {

        vector<int> dp(n+1,-1);

        return solve(n,dp);
    }
};
tabulation.cpp
class Solution {
public:

    int numTrees(int n) {

        vector<int> dp(n+1,0);

        dp[0]=1;
        dp[1]=1;

        for(int nodes=2;nodes<=n;nodes++){

            for(int root=1;root<=nodes;root++){

                dp[nodes]+=dp[root-1]*dp[nodes-root];
            }
        }

        return dp[n];
    }
};
catalan_number.cpp
class Solution {
public:

    int numTrees(int n) {

        long long ans=1;

        for(int i=0;i<n;i++){

            ans=ans*(2*n-i);

            ans=ans/(i+1);
        }

        return ans/(n+1);
    }
};
