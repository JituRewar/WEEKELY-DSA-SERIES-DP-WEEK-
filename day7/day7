01_recursion.cpp
#include <iostream>
#include <vector>
using namespace std;

int solve(vector<int>& weight, vector<int>& value,
          int index, int capacity) {

    if(index == 0) {
        if(weight[0] <= capacity)
            return value[0];
        return 0;
    }

    int notTake = solve(weight, value,
                        index-1, capacity);

    int take = 0;

    if(weight[index] <= capacity)
        take = value[index] +
               solve(weight, value,
                     index-1,
                     capacity-weight[index]);

    return max(take, notTake);
}

int main() {

    vector<int> weight = {1,2,4,5};
    vector<int> value = {5,4,8,6};

    int capacity = 5;

    cout << solve(weight, value,
                  weight.size()-1,
                  capacity);
}
02_memoization.cpp
#include <iostream>
#include <vector>
using namespace std;

int solve(vector<int>& weight,
          vector<int>& value,
          int index,
          int capacity,
          vector<vector<int>>& dp) {

    if(index == 0) {
        if(weight[0] <= capacity)
            return value[0];
        return 0;
    }

    if(dp[index][capacity] != -1)
        return dp[index][capacity];

    int notTake =
        solve(weight,value,index-1,
              capacity,dp);

    int take = 0;

    if(weight[index] <= capacity)
        take =
        value[index] +
        solve(weight,value,index-1,
              capacity-weight[index],dp);

    return dp[index][capacity] =
           max(take, notTake);
}

int main() {

    vector<int> weight={1,2,4,5};
    vector<int> value={5,4,8,6};

    int W=5;

    vector<vector<int>> dp(
        weight.size(),
        vector<int>(W+1,-1));

    cout<<solve(weight,value,
                weight.size()-1,
                W,dp);
}
03_tabulation.cpp
#include <iostream>
#include <vector>
using namespace std;

int main() {

    vector<int> wt={1,2,4,5};
    vector<int> val={5,4,8,6};

    int W=5;
    int n=wt.size();

    vector<vector<int>> dp(
        n,
        vector<int>(W+1,0));

    for(int w=wt[0];w<=W;w++)
        dp[0][w]=val[0];

    for(int i=1;i<n;i++){

        for(int w=0;w<=W;w++){

            int notTake=dp[i-1][w];

            int take=0;

            if(wt[i]<=w)
                take=val[i]+
                dp[i-1][w-wt[i]];

            dp[i][w]=max(take,notTake);
        }
    }

    cout<<dp[n-1][W];
}
04_space_optimization_2rows.cpp
#include <iostream>
#include <vector>
using namespace std;

int main() {

    vector<int> wt={1,2,4,5};
    vector<int> val={5,4,8,6};

    int W=5;

    vector<int> prev(W+1,0);
    vector<int> curr(W+1,0);

    for(int w=wt[0];w<=W;w++)
        prev[w]=val[0];

    for(int i=1;i<wt.size();i++){

        for(int w=0;w<=W;w++){

            int notTake=prev[w];

            int take=0;

            if(wt[i]<=w)
                take=val[i]+
                curr[w-wt[i]];

            curr[w]=max(take,notTake);
        }

        prev=curr;
    }

    cout<<prev[W];
}
05_space_optimization_1row.cpp
#include <iostream>
#include <vector>
using namespace std;

int main() {

    vector<int> wt={1,2,4,5};
    vector<int> val={5,4,8,6};

    int W=5;

    vector<int> dp(W+1,0);

    for(int w=wt[0];w<=W;w++)
        dp[w]=val[0];

    for(int i=1;i<wt.size();i++){

        for(int w=W;w>=0;w--){

            int notTake=dp[w];

            int take=0;

            if(wt[i]<=w)
                take=val[i]+
                dp[w-wt[i]];

            dp[w]=max(take,notTake);
        }
    }

    cout<<dp[W];
}
