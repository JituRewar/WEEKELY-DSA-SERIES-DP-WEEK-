#include <iostream>
#include <vector>
using namespace std;

//---------------------------------------------------------------
// Approach 1 : Pure Recursion
//---------------------------------------------------------------

int solveRec(vector<int>& nums, int target) {
    if (target == 0)
        return 1;

    if (target < 0)
        return 0;

    int ans = 0;

    for (int num : nums) {
        ans += solveRec(nums, target - num);
    }

    return ans;
}

//---------------------------------------------------------------
// Approach 2 : Memoization
//---------------------------------------------------------------

int solveMem(vector<int>& nums, int target, vector<int>& dp) {
    if (target == 0)
        return 1;

    if (target < 0)
        return 0;

    if (dp[target] != -1)
        return dp[target];

    int ans = 0;

    for (int num : nums) {
        ans += solveMem(nums, target - num, dp);
    }

    return dp[target] = ans;
}

//---------------------------------------------------------------
// Approach 3 : Tabulation
//---------------------------------------------------------------

int solveTab(vector<int>& nums, int target) {
    vector<unsigned long long> dp(target + 1, 0);

    dp[0] = 1;

    for (int t = 1; t <= target; t++) {
        for (int num : nums) {
            if (t - num >= 0) {
                dp[t] += dp[t - num];
            }
        }
    }

    return dp[target];
}

//---------------------------------------------------------------

int main() {

    vector<int> nums = {1, 2, 3};
    int target = 4;

    cout << "Recursion : "
         << solveRec(nums, target) << endl;

    vector<int> dp(target + 1, -1);

    cout << "Memoization : "
         << solveMem(nums, target, dp) << endl;

    cout << "Tabulation : "
         << solveTab(nums, target) << endl;

    return 0;
}
