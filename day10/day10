#include <iostream>
#include <vector>
#include <climits>
using namespace std;

//-----------------------------------------------------
// Approach 1 : Pure Recursion
//-----------------------------------------------------

int solveRec(vector<int>& days, vector<int>& costs, int index) {

    if (index >= days.size())
        return 0;

    // 1-Day Pass
    int option1 = costs[0] + solveRec(days, costs, index + 1);

    // 7-Day Pass
    int i = index;
    while (i < days.size() && days[i] < days[index] + 7)
        i++;

    int option2 = costs[1] + solveRec(days, costs, i);

    // 30-Day Pass
    i = index;
    while (i < days.size() && days[i] < days[index] + 30)
        i++;

    int option3 = costs[2] + solveRec(days, costs, i);

    return min(option1, min(option2, option3));
}

//-----------------------------------------------------
// Approach 2 : Memoization
//-----------------------------------------------------

int solveMem(vector<int>& days, vector<int>& costs, int index, vector<int>& dp) {

    if (index >= days.size())
        return 0;

    if (dp[index] != -1)
        return dp[index];

    int option1 = costs[0] + solveMem(days, costs, index + 1, dp);

    int i = index;
    while (i < days.size() && days[i] < days[index] + 7)
        i++;

    int option2 = costs[1] + solveMem(days, costs, i, dp);

    i = index;
    while (i < days.size() && days[i] < days[index] + 30)
        i++;

    int option3 = costs[2] + solveMem(days, costs, i, dp);

    return dp[index] = min(option1, min(option2, option3));
}

//-----------------------------------------------------
// Approach 3 : Tabulation
//-----------------------------------------------------

int solveTab(vector<int>& days, vector<int>& costs) {

    int n = days.size();

    vector<int> dp(n + 1, 0);

    for (int index = n - 1; index >= 0; index--) {

        int option1 = costs[0] + dp[index + 1];

        int i = index;
        while (i < n && days[i] < days[index] + 7)
            i++;

        int option2 = costs[1] + dp[i];

        i = index;
        while (i < n && days[i] < days[index] + 30)
            i++;

        int option3 = costs[2] + dp[i];

        dp[index] = min(option1, min(option2, option3));
    }

    return dp[0];
}

//-----------------------------------------------------

int main() {

    vector<int> days = {1,4,6,7,8,20};
    vector<int> costs = {2,7,15};

    cout << "Recursion : "
         << solveRec(days, costs, 0) << endl;

    vector<int> dp(days.size(), -1);

    cout << "Memoization : "
         << solveMem(days, costs, 0, dp) << endl;

    cout << "Tabulation : "
         << solveTab(days, costs) << endl;

    return 0;
}
