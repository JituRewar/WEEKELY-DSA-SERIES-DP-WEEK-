recursion.cpp
class Solution {
public:

    int solve(vector<int>& arr, int index, int diff){

        if(index == arr.size())
            return 0;

        int take = 0;

        for(int i = index + 1; i < arr.size(); i++){

            if(arr[i] - arr[index] == diff){

                take = max(take, 1 + solve(arr, i, diff));
            }
        }

        return take;
    }

    int longestSubsequence(vector<int>& arr, int difference) {

        int ans = 1;

        for(int i = 0; i < arr.size(); i++){

            ans = max(ans, 1 + solve(arr, i, difference));
        }

        return ans;
    }
};
memoization.cpp
class Solution {
public:

    int solve(vector<int>& arr, int index, int diff,
              vector<int>& dp){

        if(dp[index] != -1)
            return dp[index];

        int ans = 1;

        for(int i = index + 1; i < arr.size(); i++){

            if(arr[i] - arr[index] == diff){

                ans = max(ans,
                          1 + solve(arr, i, diff, dp));
            }
        }

        return dp[index] = ans;
    }

    int longestSubsequence(vector<int>& arr, int difference) {

        int n = arr.size();

        vector<int> dp(n, -1);

        int ans = 1;

        for(int i = 0; i < n; i++){

            ans = max(ans, solve(arr, i, difference, dp));
        }

        return ans;
    }
};
tabulation.cpp (Optimal)
class Solution {
public:

    int longestSubsequence(vector<int>& arr, int difference) {

        unordered_map<int,int> dp;

        int ans = 1;

        for(int num : arr){

            dp[num] = dp[num - difference] + 1;

            ans = max(ans, dp[num]);
        }

        return ans;
    }
};
